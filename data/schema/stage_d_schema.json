{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage D Top-k recovery row",
  "type": "object",
  "required": ["case_id", "k", "protected_layers", "found"],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "k": {"type": "integer", "minimum": 1},
    "protected_layers": {
      "type": "array",
      "items": {"type": "integer", "minimum": 0}
    },
    "found": {"type": "boolean"}
  }
}
