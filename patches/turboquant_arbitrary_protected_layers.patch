diff --git a/turboquant/compressors_v3.py b/turboquant/compressors_v3.py
index 912cb0f..42dd830 100644
--- a/turboquant/compressors_v3.py
+++ b/turboquant/compressors_v3.py
@@ -146,7 +146,9 @@ class TurboQuantV3:
         layer_idx: int = 0,
         n_layers: int = 36,
         protected_layers: int = 4,
+        protected_layer_ids: list[int] | set[int] | None = None,
         protected_bits: int = 8,
+        protected_key_bits: int = 8,
         seed: int = 42,
         device: str = "cpu",
     ):
@@ -154,10 +156,22 @@ class TurboQuantV3:
         self.residual_window = residual_window
         self.device = device
 
-        # Layer-adaptive: first/last N layers get more bits
-        is_protected = layer_idx < protected_layers or layer_idx >= (n_layers - protected_layers)
-        effective_key_bits = protected_bits if is_protected else key_bits
-        effective_value_bits = protected_bits if is_protected else value_bits
+        # Backward-compatible path: protected_layers keeps the original
+        # first/last-N semantics and raises both key and value precision.
+        is_prefix_suffix_protected = (
+            layer_idx < protected_layers or layer_idx >= (n_layers - protected_layers)
+        )
+
+        # T-BGMP path: explicit risk-ranked key layer IDs raise key precision
+        # only. Values remain at value_bits for a fair same-budget comparison.
+        protected_layer_ids = set(protected_layer_ids or [])
+        is_key_id_protected = layer_idx in protected_layer_ids
+        effective_key_bits = (
+            protected_key_bits if is_key_id_protected
+            else protected_bits if is_prefix_suffix_protected
+            else key_bits
+        )
+        effective_value_bits = protected_bits if is_prefix_suffix_protected else value_bits
 
         # Cap at 8 bits (uint8 max)
         self.key_bits = min(effective_key_bits, 8)
